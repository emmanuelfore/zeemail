# Root backend environment for VPS deployment
NODE_ENV=production
PORT=5000

# Public app URL used by the backend for callbacks, links, and CORS
APP_URL=https://yourdomain.com

# Optional extra allowed CORS origin if your frontend lives on a different domain
# CORS_ORIGIN=https://app.yourdomain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@host:6543/postgres

# Mailcow
MAILCOW_HOST=https://mail.yourdomain.com
MAILCOW_API_KEY=your-mailcow-api-key

# Business discovery / lead enrichment
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=local-business-search.p.rapidapi.com

# Paynow
PAYNOW_INTEGRATION_ID=your-paynow-integration-id
PAYNOW_INTEGRATION_KEY=your-paynow-integration-key

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Email / messaging
RESEND_API_KEY=your-resend-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
