# Supabase — server-side (backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Mailcow — server-side only, never exposed to the frontend
MAILCOW_HOST=https://mail.yourdomain.co.zw
MAILCOW_API_KEY=your-mailcow-api-key

# WhoisJSON — server-side only, never exposed to the frontend
# See README.md for instructions on obtaining this key
WHOISJSON_API_KEY=your-whoisjson-api-key

# Express server
PORT=3000

# Supabase — client-side (Vite frontend, VITE_ prefix required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API base URL used by the frontend to reach the Express backend
VITE_API_BASE_URL=http://localhost:3000

# Paynow Zimbabwe
PAYNOW_INTEGRATION_ID=your-paynow-integration-id
PAYNOW_INTEGRATION_KEY=your-paynow-integration-key

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Resend (transactional email)
RESEND_API_KEY=your-resend-api-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Application base URL (used for Paynow return URLs and email links)
APP_URL=http://localhost:3000
