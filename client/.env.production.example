# Frontend production environment for Vite
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Recommended when Nginx serves the frontend and proxies /api on the same domain
VITE_API_BASE_URL=https://yourdomain.com

# Optional UI-only Mailcow host display
VITE_MAILCOW_HOST=mail.yourdomain.com
